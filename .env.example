# Postgres connection URL (Neon serverless driver)
DATABASE_URL=

# Shared secret for Vercel Cron Authorization header (min 16 chars)
CRON_SECRET=

# Separate secret for admin mutation API routes (min 16 chars).
# Optional — falls back to CRON_SECRET if unset, but a dedicated value is recommended.
ADMIN_API_SECRET=

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Secret passed in the Telegram webhook header; min 8 chars
TELEGRAM_WEBHOOK_SECRET=

# Target Telegram channel/supergroup numeric ID (negative, starts -100…)
DEFAULT_CHANNEL_ID=

# BIP32 xprv for TRON deposit address derivation
TRON_DEPOSIT_XPRV=

# Hex private key for the hot wallet (commission payouts)
TRON_HOT_WALLET_PK=

# Cold treasury TRC20 address (T-prefix, 34 chars)
TRON_COLD_WALLET_ADDRESS=

# TronGrid API key
TRONGRID_API_KEY=

# Upstash Redis REST URL
UPSTASH_REDIS_REST_URL=

# Upstash Redis REST token
UPSTASH_REDIS_REST_TOKEN=

# Comma-separated Telegram user IDs allowed admin access (e.g. "111,222")
ADMIN_TG_IDS=

# Hard cap on a single payout tx in USDT (e.g. 1000)
MAX_PAYOUT_PER_TX_USDT=

# Hard cap on number of payout tx per hour (e.g. 30)
MAX_PAYOUTS_PER_HOUR=
